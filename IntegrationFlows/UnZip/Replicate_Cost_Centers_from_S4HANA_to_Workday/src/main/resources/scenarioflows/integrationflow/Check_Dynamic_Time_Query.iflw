                    <value>&lt;html&gt;

&lt;head&gt;
	&lt;style&gt;
	table,
	th,
	td {
		padding: 5px;
		border: 1px solid black;
		border-collapse: collapse;
	}
	&lt;/style&gt;
&lt;/head&gt;

&lt;body&gt; Dear Business,
	&lt;br&gt;
	&lt;br&gt; The Replication of Cost Center
	&lt;B&gt;${property.SAPReferenceId}&lt;/B&gt; for message "
	&lt;B&gt;${property.SAP_MessageProcessingLogID}&lt;/B&gt;" failed.
	&lt;br&gt;
	&lt;br&gt; Error details:
	&lt;br&gt;
	&lt;h4&gt; 		${exception.message} 		&lt;/h4&gt;
	&lt;br&gt; Best regards,
	&lt;br&gt; Support Team
	&lt;br&gt; &lt;/body&gt;

&lt;/html&gt;</value>
